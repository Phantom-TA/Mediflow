    "type": "function",
    "messages": [
      {
        "type": "request-start",
        "content": "Checking slot availability..."
      }
    ],
    "function": {
      "name": "check_availability",
      "description": "Get all available slots for a specific doctor on a specific date.",
      "parameters": {
        "type": "object",
        "properties": {
          "doctor_id": {
            "type": "string",
            "format": "uuid",
            "description": "The UUID of the doctor."
          },
          "date": {
            "type": "string",
            "description": "Preferred date in YYYY-MM-DD format."
          }
        },
        "required": ["doctor_id", "date"]
      }
    }
  },
  {
