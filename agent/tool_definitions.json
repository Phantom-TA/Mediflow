      {
        "type": "request-start",
        "content": "Booking your appointment..."
      }
    ],
    "function": {
      "name": "book_appointment",
      "description": "Book a new appointment slot for a patient. Ensure slot_id and doctor_id are retrieved from check_availability or recommend_alternatives.",
      "parameters": {
        "type": "object",
        "properties": {
          "slot_id": {
            "type": "string",
            "format": "uuid",
