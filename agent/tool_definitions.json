          "doctor_id": {
            "type": "string",
            "format": "uuid",
            "description": "The UUID of the doctor."
          },
          "patient_name": {
            "type": "string",
            "description": "Full name of the patient."
          },
          "patient_phone": {
            "type": "string",
            "description": "Phone number of the patient (E.164 format, e.g. +919876543210)."
          },
          "reason": {
            "type": "string",
            "description": "Brief description of the health concern or symptom."
          }
        },
        "required": ["slot_id", "doctor_id", "patient_name", "patient_phone"]
      }
    }
  },
