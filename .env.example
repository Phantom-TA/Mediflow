# MediFlow Environment Variables
# Copy this file to .env and fill in values before running.

# ──────────────────────────────────────────────
# Database (Supabase PostgreSQL)
# ──────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg2://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
DATABASE_URL_ASYNC=postgresql+asyncpg://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
DATABASE_URL_TEST=postgresql+psycopg2://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres_test

# ──────────────────────────────────────────────
# App Settings
# ──────────────────────────────────────────────
APP_ENV=development       # development | staging | production
APP_PORT=8000
APP_VERSION=1.0.0
LOG_LEVEL=INFO
TIMEZONE=Asia/Kolkata

# ──────────────────────────────────────────────
# Security
# ──────────────────────────────────────────────
VAPI_SECRET=your-shared-secret-here   # Must match Vapi webhook secret
API_SECRET_KEY=your-api-secret-key    # For internal JWT if needed

# ──────────────────────────────────────────────
# Vapi
# ──────────────────────────────────────────────
VAPI_API_KEY=your-vapi-api-key
VAPI_PHONE_NUMBER_ID=your-vapi-phone-number-id
VAPI_ASSISTANT_ID=your-vapi-assistant-id

# ──────────────────────────────────────────────
# OpenAI (GPT-4o-mini)
# ──────────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key

# ──────────────────────────────────────────────
# Slot Generation
# ──────────────────────────────────────────────
SLOT_GENERATION_DAYS=14       # Generate slots this many days ahead
SLOT_DURATION_MINUTES=15      # Default consultation slot length

# ──────────────────────────────────────────────
# CORS (comma-separated origins)
# ──────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app
